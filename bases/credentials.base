filters:
  and:
    - file.inFolder("wiki/credentials")
    - type == "credential"
formulas:
  has_category: if(credential_category, credential_category, "—")
  has_claims: if(claims_supported, claims_supported.length, 0)
  claims_list: if(claims_supported, claims_supported.join(", "), "—")
  days_since_update: if(last_updated, (today() - date(last_updated)).days, "")
  source_count: if(sources, sources.length, 0)
properties:
  credential_category:
    displayName: Category
  health_wording_mode:
    displayName: Health wording
  formula.has_category:
    displayName: Category
  formula.has_claims:
    displayName: "# claims"
  formula.claims_list:
    displayName: Claims supported
  formula.days_since_update:
    displayName: Days old
  formula.source_count:
    displayName: "# sources"
views:
  - type: table
    name: Credentials registry
    order:
      - file.name
      - title
      - formula.has_category
      - formula.has_claims
      - formula.claims_list
      - health_wording_mode
      - last_updated
      - formula.days_since_update
  - type: table
    name: Missing credential_category
    filters:
      and:
        - "!credential_category"
    order:
      - file.name
      - title
      - last_updated
  - type: cards
    name: Credential cards
    order:
      - file.name
      - title
      - formula.has_category
      - formula.claims_list
