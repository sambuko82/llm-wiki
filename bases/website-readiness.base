filters:
  or:
    - type == "destination"
    - type == "product"
    - type == "person"
    - type == "credential"
    - type == "website"
    - type == "seo"
formulas:
  days_since_update: if(last_updated, (today() - date(last_updated)).days, "")
  source_count: if(sources, sources.length, 0)
  stale_flag: if(stale_after_days && last_updated, if((today() - date(last_updated)).days > stale_after_days, "⚠️ stale", "✅ fresh"), "—")
  health_wording: if(health_wording_mode, health_wording_mode, "—")
properties:
  type:
    displayName: Type
  last_updated:
    displayName: Last updated
  stale_after_days:
    displayName: Stale (days)
  owner:
    displayName: Owner
  health_wording_mode:
    displayName: Health wording
  formula.days_since_update:
    displayName: Days old
  formula.source_count:
    displayName: "# sources"
  formula.stale_flag:
    displayName: Status
  formula.health_wording:
    displayName: Health wording
views:
  - type: table
    name: All website-relevant pages (staleness order)
    order:
      - file.name
      - title
      - type
      - formula.stale_flag
      - last_updated
      - formula.days_since_update
      - stale_after_days
      - formula.source_count
    summaries:
      formula.days_since_update: Average
  - type: table
    name: Stale pages
    filters:
      and:
        - stale_after_days
        - last_updated
        - (today() - date(last_updated)).days > stale_after_days
    order:
      - file.name
      - title
      - type
      - last_updated
      - formula.days_since_update
      - stale_after_days
  - type: table
    name: Ijen health-wording pages
    filters:
      and:
        - health_wording_mode == "conditional"
    order:
      - file.name
      - title
      - type
      - formula.health_wording
      - last_updated
      - formula.stale_flag
  - type: cards
    name: Domain cards
    order:
      - file.name
      - title
      - type
      - formula.stale_flag
      - last_updated
