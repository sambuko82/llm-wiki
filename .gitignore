# Obsidian workspace state (changes on every open, not content)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# OS junk
.DS_Store
Thumbs.db
desktop.ini
.gstack/
.codex-run/

# Runtime cache generated by the JVTO MAGMA feed collector
magma-feed/data/
magma-feed/exports/

# Playwright MCP browser session artifacts
.playwright-mcp/

# Obsidian graph layout state (changes on every pan/zoom, not content)
.obsidian/graph.json

# Backoffice MySQL dumps — contain PII, never commit
raw/backoffice/dumps/
raw/backoffice/csv/
raw/backoffice/_inventory.json
raw/backoffice/_export_summary.json

# Python bytecode
__pycache__/
*.pyc
